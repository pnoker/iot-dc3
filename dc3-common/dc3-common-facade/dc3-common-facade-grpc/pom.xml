<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.github.pnoker</groupId>
        <artifactId>dc3-common-facade</artifactId>
        <version>2026.5.22</version>
    </parent>

    <name>${project.artifactId}</name>
    <artifactId>dc3-common-facade-grpc</artifactId>
    <version>2026.5.22</version>
    <packaging>jar</packaging>

    <inceptionYear>2016</inceptionYear>
    <url>https://github.com/pnoker/iot-dc3</url>
    <description>
        gRPC implementation of the Facade API, selected when dc3.facade.mode=grpc (default).
        Holds BlockingStubs and translates between Facade BO/Query and protobuf DTOs.
    </description>

    <dependencies>

        <!-- gRPC Related -->
        <dependency>
            <groupId>org.springframework.grpc</groupId>
            <artifactId>spring-grpc-spring-boot-starter</artifactId>
        </dependency>

        <!-- DC3 API Related -->
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-api-auth</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-api-data</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-api-manager</artifactId>
        </dependency>

        <!-- DC3 Common Related -->
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-api</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-exception</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-facade-api</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-public</artifactId>
        </dependency>


        <!-- OpenAPI annotations -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-common</artifactId>
        </dependency>
    </dependencies>

</project>
