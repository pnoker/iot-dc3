<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.github.pnoker</groupId>
        <artifactId>dc3-common-facade</artifactId>
        <version>2026.5.22</version>
    </parent>

    <name>${project.artifactId}</name>
    <artifactId>dc3-common-facade-local</artifactId>
    <version>2026.5.22</version>
    <packaging>pom</packaging>

    <inceptionYear>2016</inceptionYear>
    <url>https://github.com/pnoker/iot-dc3</url>
    <description>
        Convenience aggregator for the local (in-process) facade implementations. Depending on
        this artifact pulls in every local facade domain (auth + data + manager). Single-node deployments
        that need the full surface should depend on this module; services that only need one
        domain (for example dc3-center-auth) should depend on the specific sub-module to avoid
        unrelated transitive dependencies (e.g. RabbitMQ).
    </description>

    <dependencies>

        <!-- Domain-scoped local facade implementations -->
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-facade-local-auth</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-facade-local-data</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-facade-local-manager</artifactId>
        </dependency>


        <!-- OpenAPI annotations -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-common</artifactId>
        </dependency>
    </dependencies>

</project>
