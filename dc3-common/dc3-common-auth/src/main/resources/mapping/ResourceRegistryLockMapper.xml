<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pnoker.common.auth.mapper.ResourceRegistryLockMapper">

    <!--
      PostgreSQL's pg_advisory_xact_lock returns void. MyBatis cannot map a
      columnless ResultSet to a Java type, so we cast the result to ::text
      (PostgreSQL renders an empty string). The return value is discarded by
      callers; we only need the side effect of acquiring the lock.
    -->
    <select id="advisoryLock" resultType="java.lang.String">
        SELECT pg_advisory_xact_lock(hashtext(#{key})) ::text
    </select>

</mapper>
