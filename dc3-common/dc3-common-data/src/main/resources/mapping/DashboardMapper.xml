<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pnoker.common.data.mapper.DashboardMapper">

    <select id="countInRange" resultType="long">
        SELECT COUNT(*)
        FROM dc3_point_value
        WHERE create_time &gt;= #{from}
        AND create_time &lt; #{to}
        AND tenant_id = #{tenantId}
    </select>

    <select id="countTotal" resultType="long">
        SELECT COUNT(*)
        FROM dc3_point_value
        WHERE tenant_id = #{tenantId}
    </select>

    <!--
        bucket is inlined via ${} rather than bound as #{}:
        Postgres JDBC resolves the prepared statement's parameter types
        before any CAST runs, and refuses "?::interval" / CAST(? AS interval)
        because it can't infer a type for a bare '?'. The service layer
        already whitelists bucket to '1 hour' or '1 day' (no user input),
        so inlining it as a SQL literal is safe and sidesteps the issue.

        time_bucket is qualified with the "public" schema because the
        TimescaleDB extension installs there (pg_extension confirms
        extnamespace=public), while this DataSource's currentSchema is
        dc3_history. Qualifying the function keeps the session
        search_path single-purpose instead of pulling public in.
    -->
    <select id="timeseries" resultType="io.github.pnoker.common.data.entity.bo.dashboard.TimeBucketRow">
        SELECT public.time_bucket(INTERVAL '${bucket}', create_time) AS bucket,
        COUNT(*) AS count
        FROM dc3_point_value
        WHERE create_time &gt;= #{from}
        AND create_time &lt; #{to}
        AND tenant_id = #{tenantId}
        GROUP BY bucket
        ORDER BY bucket ASC
    </select>

    <!--
        ${dimension} is interpolated directly. Service layer must validate it
        against a whitelist (device_id / point_id / driver_id) — never accept
        user input.
    -->
    <select id="top" resultType="io.github.pnoker.common.data.entity.bo.dashboard.EntityCountRow">
        SELECT ${dimension} AS entity_id,
        COUNT(*) AS count
        FROM dc3_point_value
        WHERE create_time &gt;= #{from}
        AND create_time &lt; #{to}
        AND tenant_id = #{tenantId}
        GROUP BY ${dimension}
        ORDER BY count DESC
        LIMIT #{limit}
    </select>

    <!--
        Latest stream: a single hypertable now holds every sample regardless
        of declared point type, so the value_type column is derived from the
        num_value projection — NUMERIC when cal_value parsed cleanly as a
        double, STRING otherwise (booleans, JSON, free-form text).
    -->
    <select id="latestStream" resultType="io.github.pnoker.common.data.entity.bo.dashboard.LatestPointValueRow">
        SELECT tenant_id,
        device_id,
        point_id,
        driver_id,
        create_time,
        raw_value,
        cal_value,
        CASE WHEN num_value IS NOT NULL THEN 'NUMERIC' ELSE 'STRING' END AS value_type
        FROM dc3_point_value
        WHERE tenant_id = #{tenantId}
        ORDER BY create_time DESC
        LIMIT #{limit}
    </select>

    <!--
        Latency histogram: operate_time is stamped at persistence, create_time
        is the driver's acquisition timestamp, so the diff is the pipeline
        latency in milliseconds. Fixed six-bucket layout matches the UI
        labels (&lt;100ms, 100-500ms, 500ms-1s, 1-5s, 5-30s, &gt;=30s).
    -->
    <select id="latencyHistogram" resultType="io.github.pnoker.common.data.entity.bo.dashboard.LatencyBinRow">
        SELECT bin, COUNT(*) AS count
        FROM (SELECT CASE
        WHEN diff_ms &lt; 100 THEN 0
        WHEN diff_ms &lt; 500 THEN 1
        WHEN diff_ms &lt; 1000 THEN 2
        WHEN diff_ms &lt; 5000 THEN 3
        WHEN diff_ms &lt; 30000 THEN 4
        ELSE 5
        END AS bin
        FROM (SELECT EXTRACT(EPOCH FROM (operate_time - create_time)) * 1000 AS diff_ms
        FROM dc3_point_value
        WHERE create_time &gt;= #{from}
        AND create_time &lt; #{to}
        AND tenant_id = #{tenantId}) deltas) bucketed
        GROUP BY bin
        ORDER BY bin ASC
    </select>

    <!--
        Hourly activity: dow 0=Sunday..6=Saturday, hour 0..23. Rows are only
        emitted for (dow, hour) pairs that had data; the frontend fills in
        the missing cells as zero.
    -->
    <select id="hourlyActivity" resultType="io.github.pnoker.common.data.entity.bo.dashboard.ActivityCellRow">
        SELECT EXTRACT(DOW FROM create_time)::int AS dow, EXTRACT(HOUR FROM create_time)::int AS hour, COUNT(*) AS count
        FROM dc3_point_value
        WHERE create_time &gt;= #{from}
        AND create_time &lt; #{to}
        AND tenant_id = #{tenantId}
        GROUP BY dow, hour
        ORDER BY dow ASC, hour ASC
    </select>

    <!-- =========================================================
         Phase-2 insight queries — still on the history DS.
         ========================================================= -->

    <!--
        Silent sources: (device_id, point_id) pairs that had samples in
        the baseline window ({@code from} .. {@code silentThreshold}) but
        have had NO sample since {@code silentThreshold}. MAX(create_time)
        &lt; threshold is the "gone quiet" test. The outer baseline filter
        keeps fresh-install points (never reported) out — those belong in
        coverage-gap, not silence.
    -->
    <select id="silentSources" resultType="io.github.pnoker.common.data.entity.bo.dashboard.SilentSourceRow">
        SELECT device_id, point_id, MAX(create_time) AS last_seen
        FROM dc3_point_value
        WHERE tenant_id = #{tenantId}
        AND create_time &gt;= #{from}
        GROUP BY device_id, point_id
        HAVING MAX(create_time) &lt; #{silentThreshold}
        ORDER BY last_seen DESC
        LIMIT #{limit}
    </select>

    <!--
        Coverage gap: points in dc3_manager.dc3_point with zero pv rows
        ever. NOT EXISTS is the cheapest anti-join for this shape on PG.
        Cross-schema qualification is fine because the same user owns
        both schemas and dynamic datasource only sets search_path.
    -->
    <select id="coverageGapItems" resultType="io.github.pnoker.common.data.entity.bo.dashboard.CoverageGapRow">
        SELECT p.id AS point_id, p.profile_id AS profile_id
        FROM dc3_manager.dc3_point p
        WHERE p.deleted = 0
        AND p.tenant_id = #{tenantId}
        AND NOT EXISTS (SELECT 1
        FROM dc3_point_value pv
        WHERE pv.point_id = p.id
        AND pv.tenant_id = p.tenant_id)
        ORDER BY p.id DESC
        LIMIT #{limit}
    </select>

    <select id="countPointsInTenant" resultType="long">
        SELECT COUNT(*)
        FROM dc3_manager.dc3_point
        WHERE deleted = 0
        AND tenant_id = #{tenantId}
    </select>

</mapper>
