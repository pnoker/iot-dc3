<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pnoker.common.manager.mapper.EventMapper">

    <select id="selectPageWithDevice" resultType="io.github.pnoker.common.manager.entity.model.EventDO">
        select
        de.id,
        de.event_name,
        de.event_code,
        de.event_type_flag,
        de.event_level_flag,
        de.event_ext,
        de.profile_id,
        de.enable_flag,
        de.tenant_id,
        de.remark,
        de.signature,
        de.version,
        de.creator_id,
        de.creator_name,
        de.create_time,
        de.operator_id,
        de.operator_name,
        de.operate_time,
        de.deleted
        from dc3_event de
        <if test="deviceId != null and deviceId > 0">
            inner join dc3_device dd
            on dd.profile_id = de.profile_id
            and dd.id = #{deviceId}
            and dd.tenant_id = de.tenant_id
            and dd.deleted = 0
        </if>
        ${ew.customSqlSegment}
    </select>
</mapper>
