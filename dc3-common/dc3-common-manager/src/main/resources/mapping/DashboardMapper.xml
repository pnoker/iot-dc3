<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.pnoker.common.manager.mapper.DashboardMapper">

    <!--
        Every GROUP BY column is aliased to `key` so a single BucketRow
        (key, count) can serve all five bucket-shaped queries below. Reuse
        instead of one Row class per group column.
    -->
    <select id="countDriverByEnable"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.BucketRow">
        SELECT enable_flag AS key, COUNT(*) AS count
        FROM dc3_driver
        WHERE deleted = 0
        AND tenant_id = #{tenantId}
        GROUP BY enable_flag
    </select>

    <select id="countDriverByType"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.BucketRow">
        SELECT driver_type_flag AS key, COUNT(*) AS count
        FROM dc3_driver
        WHERE deleted = 0
        AND tenant_id = #{tenantId}
        GROUP BY driver_type_flag
    </select>

    <!--
        driver_type_flag is only client/server — the real "protocol" identity
        lives in service_name (e.g. dc3-driver-modbus-tcp / dc3-driver-mqtt).
        Group by that so the home dashboard can show the actual protocol mix.
    -->
    <select id="countDriverByService"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.BucketRow">
        SELECT service_name AS key, COUNT(*) AS count
        FROM dc3_driver
        WHERE deleted = 0
        AND tenant_id = #{tenantId}
        GROUP BY service_name
        ORDER BY count
        DESC
    </select>

    <select id="countDeviceByEnable"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.BucketRow">
        SELECT enable_flag AS key, COUNT(*) AS count
        FROM dc3_device
        WHERE deleted = 0
        AND tenant_id = #{tenantId}
        GROUP BY enable_flag
    </select>

    <select id="countDeviceByDriver"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.BucketRow">
        SELECT driver_id AS key, COUNT(*) AS count
        FROM dc3_device
        WHERE deleted = 0
        AND tenant_id = #{tenantId}
        GROUP BY driver_id
        ORDER BY count
        DESC
        LIMIT #{limit}
    </select>

    <!--
        Device count grouped by profile_id. Only devices with a non-null
        profile_id are counted.
    -->
    <select id="countDeviceByProfile"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.BucketRow">
        SELECT d.profile_id AS key, COUNT(*) AS count
        FROM dc3_device d
        WHERE d.deleted = 0
        AND d.tenant_id = #{tenantId}
        AND d.profile_id IS NOT NULL
        GROUP BY d.profile_id
        ORDER BY count
        DESC
        LIMIT #{limit}
    </select>

    <!--
        Daily new-row count over the given window. ${table} is inlined
        (service layer whitelists to dc3_driver / dc3_device / dc3_point).
        Missing days are filled with zero on the service side.
    -->
    <select id="dailyGrowth"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.DailyGrowthRow">
        SELECT DATE(create_time) AS day, COUNT(*) AS count
        FROM ${table}
        WHERE deleted = 0
        AND tenant_id = #{tenantId}
        AND create_time &gt;= #{from}
        AND create_time &lt; #{to}
        GROUP BY DATE(create_time)
        ORDER BY day ASC
    </select>

    <!-- =========================================================
         Topology (Driver → Device → Profile → Point)

         Five focused queries the service layer stitches together. We keep
         the SQL simple (one table or one join per query) and do Top-N /
         Others aggregation in Java.
         ========================================================= -->

    <select id="topologyDrivers"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.TopologyDriverRow">
        SELECT d.id AS id,
        d.driver_name AS driver_name,
        COUNT(dev.id) AS device_count
        FROM dc3_driver d
        LEFT JOIN dc3_device dev
        ON dev.driver_id = d.id
        AND dev.tenant_id = d.tenant_id
        AND dev.deleted = 0
        WHERE d.deleted = 0
        AND d.tenant_id = #{tenantId}
        GROUP BY d.id, d.driver_name
    </select>

    <select id="topologyDevicesByDrivers"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.TopologyDeviceRow">
        SELECT dev.id AS id,
        dev.device_name AS device_name,
        dev.driver_id AS driver_id,
        (CASE WHEN dev.profile_id IS NOT NULL THEN 1 ELSE 0 END) AS profile_count
        FROM dc3_device dev
        WHERE dev.deleted = 0
        AND dev.tenant_id = #{tenantId}
        AND dev.driver_id IN
        <foreach collection="driverIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="topologyProfileBindings"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.ProfileBindingRow">
        SELECT d.profile_id AS profile_id,
        d.id AS device_id
        FROM dc3_device d
        WHERE d.deleted = 0
        AND d.tenant_id = #{tenantId}
        AND d.profile_id IS NOT NULL
        AND d.id IN
        <foreach collection="deviceIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="topologyProfilesByIds"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.TopologyProfileRow">
        SELECT p.id AS id,
        p.profile_name AS profile_name
        FROM dc3_profile p
        WHERE p.deleted = 0
        AND p.tenant_id = #{tenantId}
        AND p.id IN
        <foreach collection="profileIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="topologyPointsByProfiles"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.TopologyPointRow">
        SELECT pt.id AS id,
        pt.point_name AS point_name,
        pt.profile_id AS profile_id
        FROM dc3_point pt
        WHERE pt.deleted = 0
        AND pt.tenant_id = #{tenantId}
        AND pt.profile_id IN
        <foreach collection="profileIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <!--
        Cross-schema query: view lives in dc3_history (Timescale hypertable
        union) while this DataSource's currentSchema is dc3_manager. The dc3
        user owns both schemas so fully-qualifying the view works; this
        keeps us from having to register a second dynamic datasource just
        for one aggregate call.
    -->
    <select id="topologyPointVolumes"
            resultType="io.github.pnoker.common.manager.entity.bo.dashboard.PointVolumeRow">
        SELECT device_id AS device_id,
        point_id AS point_id,
        COUNT(*) AS cnt
        FROM dc3_history.dc3_point_value
        WHERE tenant_id = #{tenantId}
        AND create_time &gt;= #{from}
        GROUP BY device_id, point_id
    </select>

</mapper>
