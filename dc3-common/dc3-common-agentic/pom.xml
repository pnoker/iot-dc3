<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>io.github.pnoker</groupId>
        <artifactId>dc3-common</artifactId>
        <version>2026.5.22</version>
    </parent>

    <name>${project.artifactId}</name>
    <artifactId>dc3-common-agentic</artifactId>
    <packaging>jar</packaging>

    <description>
        AI Agentic module for IoT DC3 platform — provides OpenAI-compatible streaming chat
        with tool-calling capabilities against auth, manager, and data services.
    </description>

    <dependencies>

        <!-- AI Related -->
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-chat-memory-repository-jdbc</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-openai</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.ai</groupId>
            <artifactId>spring-ai-starter-model-anthropic</artifactId>
        </dependency>

        <!-- DC3 Common Related -->
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-constant</artifactId>
            <version>${dc3.version}</version>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-dal</artifactId>
            <version>${dc3.version}</version>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-facade-api</artifactId>
            <version>${dc3.version}</version>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-postgres</artifactId>
            <version>${dc3.version}</version>
        </dependency>
        <dependency>
            <groupId>io.github.pnoker</groupId>
            <artifactId>dc3-common-web</artifactId>
            <version>${dc3.version}</version>
        </dependency>

        <!-- Reactive test utilities for controller verification -->
        <dependency>
            <groupId>io.projectreactor</groupId>
            <artifactId>reactor-test</artifactId>
            <scope>test</scope>
        </dependency>

    </dependencies>

</project>
