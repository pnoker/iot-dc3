    "dc3",
    "web",
    "vue3",
    "typescript",
    "element-plus",
    "tauri"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite --host --mode dev",
    "build": "vite build",
    "build:tauri": "tauri build",
    "preview": "vite preview",
    "check": "vue-tsc --noEmit --skipLibCheck",
    "format": "prettier --write .",
    "lint": "eslint --fix src/**/*.{vue,ts,js,jsx,tsx}",
    "tauri": "tauri"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@antv/g2": "^5.4.8",
    "@element-plus/icons-vue": "^2.3.2",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-shell": "^2.3.4",
    "axios": "^1.13.2",
    "clipboard": "^2.0.11",
    "core-js": "^3.47.0",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.1",
    "highlight.js": "^11.11.1",
    "js-base64": "^3.7.8",
    "js-cookie": "^3.0.5",
    "js-md5": "^0.8.3",
    "json-bigint": "^1.0.0",
    "marked": "^17.0.1",
    "mitt": "^3.0.1",
    "moment": "^2.30.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "screenfull": "^6.0.2",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@types/js-cookie": "^3.0.6",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^25.0.8",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-legacy": "^7.2.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/eslint-config-typescript": "^14.6.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "minimist": "^1.2.8",
    "prettier": "^3.8.0",
    "prettier-eslint": "^16.4.2",
    "sass": "^1.97.2",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.2.2"
  },
  "lint-staged": {
    "*.{vue,js,ts,jsx,tsx}": [
      "node scripts/add-license-header.js --check",
      "eslint --fix",
      "prettier --write"
    ],
    "*.{scss,css}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
